---
// 菌路 SMA 标识 — 直接使用品牌资产 public/logo-mark.png(深绿六边形核心 + 斜向受控路径 + 中央切换节点)。
// 不再手绘 SVG 复刻:矢量化复刻与原标识有偏差,品牌标识以真实资产为准(守 logo 规范)。
interface Props {
  size?: number;
  class?: string;
  eager?: boolean;
  light?: boolean; // 深底场景用反白版(白色标识)
}
const { size = 40, class: cls = '', eager = false, light = false } = Astro.props;
const src = light ? '/brand/logo-mark-light.png' : '/logo-mark.png';
---

<img
  src={src}
  width={size}
  height={size}
  alt="菌路 SMA 标识"
  class={`logo-mark ${cls}`}
  decoding="async"
  loading={eager ? 'eager' : 'lazy'}
/>

<style>
  .logo-mark {
    display: block;
    object-fit: contain;
  }
</style>

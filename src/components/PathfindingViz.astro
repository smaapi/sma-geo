---
// 真菌寻路可视化 — 抽象黏菌(Physarum)寻路:候选路径暗淡探索,最优路径发光,
// 单循环叙事(5.6s):探索光点先行(上下候选路,中途消散)→ 路由核确认 → 流光沿最优路径推进 → 目标点亮。
// 呼应 SMA 智能路由的生物学灵感(L1);不画具象菌丝(守 logo 规范)。纯 SVG + CSS,无运行时 JS。
interface Props {
  class?: string;
}
const { class: cls = '' } = Astro.props;

// 路径几何(主线/光晕/流光共用 BEST,探索光点各走候选路)
const BEST = 'M54 116 C150 116 150 108 240 108 C330 108 330 102 426 102';
const CAND_UP = 'M54 116 C132 60 190 54 240 108';
const CAND_DOWN = 'M54 116 C132 170 190 176 240 108';
---

<div class={`pf ${cls}`} aria-hidden="true">
  <svg viewBox="0 0 480 200" fill="none" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="xMidYMid meet">
    <defs>
      <radialGradient id="pfHalo" cx="50%" cy="54%" r="62%">
        <stop offset="0%" stop-color="#2f7d5e" stop-opacity="0.26" />
        <stop offset="100%" stop-color="#07130f" stop-opacity="0" />
      </radialGradient>
      <linearGradient id="pfBestGrad" x1="54" y1="0" x2="426" y2="0" gradientUnits="userSpaceOnUse">
        <stop offset="0%" stop-color="#3f9e78" />
        <stop offset="55%" stop-color="#5fd6a3" />
        <stop offset="100%" stop-color="#b6f5d8" />
      </linearGradient>
      <filter id="pfSoft" x="-60%" y="-60%" width="220%" height="220%">
        <feGaussianBlur stdDeviation="4.5" />
      </filter>
      <filter id="pfGlow" x="-80%" y="-80%" width="260%" height="260%">
        <feGaussianBlur stdDeviation="2.6" result="b" />
        <feMerge><feMergeNode in="b" /><feMergeNode in="SourceGraphic" /></feMerge>
      </filter>
    </defs>

    <ellipse cx="240" cy="104" rx="216" ry="86" fill="url(#pfHalo)" />

    <!-- 候选路径:多条可能,黏菌暗淡探索(错相呼吸) -->
    <g fill="none" stroke="#5fd6a3" stroke-linecap="round" stroke-width="1.5">
      <path class="pf-cand pf-cand-a" d={CAND_UP} />
      <path class="pf-cand pf-cand-b" d={CAND_DOWN} />
      <path class="pf-cand pf-cand-dead" d="M240 108 C302 78 346 62 408 56" />
    </g>

    <!-- 候选路径上的微弱中继点 -->
    <g class="pf-junctions" fill="#5fd6a3">
      <circle cx="157.5" cy="70.8" r="2" />
      <circle cx="157.5" cy="157.8" r="2" />
      <circle cx="324" cy="73" r="2" />
    </g>

    <!-- 最优路径:光晕底 + 渐变主线 -->
    <path class="pf-best-glow" d={BEST} stroke="#5fd6a3" stroke-width="8" stroke-linecap="round" filter="url(#pfSoft)" />
    <path class="pf-best" d={BEST} stroke="url(#pfBestGrad)" stroke-width="2.6" stroke-linecap="round" />

    <!-- 探索光点:先行试探候选路,中途消散 -->
    <circle class="pf-scout pf-scout-up" r="2.4" fill="#8fe6bf" />
    <circle class="pf-scout pf-scout-down" r="2.4" fill="#8fe6bf" />

    <!-- 流光:halo + core,沿最优路径推进 -->
    <circle class="pf-comet-halo" r="9" fill="#aef4d4" filter="url(#pfSoft)" />
    <circle class="pf-comet" r="3.2" fill="#eafff6" filter="url(#pfGlow)" />

    <!-- 节点 -->
    <circle class="pf-src" cx="54" cy="116" r="6" />
    <circle class="pf-dead" cx="408" cy="56" r="4" />

    <!-- 路由核(呼应 logo 中央切换节点) -->
    <g class="pf-core">
      <rect x="225" y="93" width="30" height="30" rx="8" fill="#07130f" stroke="#7ee6b6" stroke-width="2" />
      <rect x="234" y="102" width="12" height="12" rx="3.5" fill="#5fd6a3" />
    </g>

    <!-- 目标(最优模型):流光抵达时点亮 -->
    <circle class="pf-dst" cx="426" cy="102" r="7" />
    <circle class="pf-dst-ring" cx="426" cy="102" r="7" />
  </svg>
</div>

<style define:vars={{ best: `path("${BEST}")`, candUp: `path("${CAND_UP}")`, candDown: `path("${CAND_DOWN}")` }}>
  .pf {
    width: 100%;
    max-width: 520px;
    margin: 0 auto;
  }
  .pf svg {
    width: 100%;
    height: auto;
    display: block;
  }

  /* —— 单循环 5.6s:0-36% 探索,36-40% 确认,38-92% 流光,88-100% 抵达 —— */

  .pf-cand {
    opacity: 0.22;
  }
  .pf-cand-a { animation: pfBreatheA 5.6s ease-in-out infinite; }
  .pf-cand-b { animation: pfBreatheB 5.6s ease-in-out infinite; }
  .pf-cand-dead { opacity: 0.14; animation: pfBreatheDead 5.6s ease-in-out infinite; }
  @keyframes pfBreatheA {
    0%, 100% { opacity: 0.18; }
    18% { opacity: 0.34; }
    48% { opacity: 0.18; }
  }
  @keyframes pfBreatheB {
    0%, 100% { opacity: 0.18; }
    28% { opacity: 0.34; }
    56% { opacity: 0.18; }
  }
  @keyframes pfBreatheDead {
    0%, 100% { opacity: 0.12; }
    52% { opacity: 0.22; }
  }

  .pf-junctions {
    opacity: 0.3;
  }

  .pf-best {
    opacity: 0.96;
  }
  .pf-best-glow {
    opacity: 0.3;
  }

  .pf-src { fill: #b6f5d8; }
  .pf-dead { fill: #2f7d5e; opacity: 0.4; }
  .pf-dst {
    fill: #07130f;
    stroke: #5fd6a3;
    stroke-width: 2;
  }
  .pf-dst-ring {
    fill: none;
    stroke: #aef4d4;
    stroke-width: 2;
    transform-origin: 426px 102px;
    opacity: 0;
    animation: pfArrive 5.6s ease-out infinite;
  }
  @keyframes pfArrive {
    0%, 84% { opacity: 0; transform: scale(0.7); }
    92% { opacity: 0.9; transform: scale(1.7); }
    100% { opacity: 0; transform: scale(2.3); }
  }

  .pf-core {
    transform-origin: 240px 108px;
    animation: pfConfirm 5.6s ease-in-out infinite;
  }
  @keyframes pfConfirm {
    0%, 28% { opacity: 0.78; }
    38% { opacity: 1; }
    72% { opacity: 0.88; }
    100% { opacity: 0.78; }
  }

  /* 探索光点:候选路上行至中途消散("尝试"先于"选定") */
  .pf-scout {
    offset-rotate: 0deg;
  }
  .pf-scout-up {
    offset-path: var(--candUp);
    animation: pfScoutUp 5.6s ease-in-out infinite;
  }
  .pf-scout-down {
    offset-path: var(--candDown);
    animation: pfScoutDown 5.6s ease-in-out infinite;
  }
  @keyframes pfScoutUp {
    0% { offset-distance: 0%; opacity: 0; }
    4% { opacity: 0.9; }
    30% { offset-distance: 60%; opacity: 0; }
    100% { offset-distance: 60%; opacity: 0; }
  }
  @keyframes pfScoutDown {
    0%, 7% { offset-distance: 0%; opacity: 0; }
    11% { opacity: 0.8; }
    38% { offset-distance: 58%; opacity: 0; }
    100% { offset-distance: 58%; opacity: 0; }
  }

  /* 流光:探索结束后才出发 */
  .pf-comet,
  .pf-comet-halo {
    offset-path: var(--best);
    offset-rotate: 0deg;
  }
  .pf-comet {
    animation: pfTravel 5.6s cubic-bezier(0.45, 0, 0.25, 1) infinite;
  }
  .pf-comet-halo {
    animation: pfTravelHalo 5.6s cubic-bezier(0.45, 0, 0.25, 1) infinite;
  }
  @keyframes pfTravel {
    0%, 34% { offset-distance: 0%; opacity: 0; }
    40% { opacity: 1; }
    86% { opacity: 1; }
    92%, 100% { offset-distance: 100%; opacity: 0; }
  }
  @keyframes pfTravelHalo {
    0%, 34% { offset-distance: 0%; opacity: 0; }
    40% { opacity: 0.5; }
    86% { opacity: 0.5; }
    92%, 100% { offset-distance: 100%; opacity: 0; }
  }

  @media (prefers-reduced-motion: reduce) {
    .pf-comet,
    .pf-comet-halo,
    .pf-scout { opacity: 0; animation: none; }
    .pf-dst-ring,
    .pf-core,
    .pf-cand { animation: none; }
    .pf-core { opacity: 1; }
  }
</style>

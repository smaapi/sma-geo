---
import pagesData from '../data/pages.json';
import { organization, website, breadcrumb } from '../lib/schema';
import Logo from '../components/Logo.astro';

interface Props {
  route: string;
  theme?: 'light' | 'dark';
}

const { route, theme = 'light' } = Astro.props;
const isDark = theme === 'dark';
const site = pagesData.site;
const page = pagesData.pages.find((p) => p.route === route);
if (!page) throw new Error(`route not in src/data/pages.json registry: ${route}`);
const alt = pagesData.pages.find((p) => p.route === page.alternate);
const zh = page.lang === 'zh';
const canonical = site + route;
const xDefault = zh ? (alt ? site + alt.route : canonical) : canonical;
// P2 面包屑:非首页生成 Home > 当前页(短标签取自注册表 llms.label)
const isHome = route === '/' || route === '/en/';
const crumb = isHome
  ? null
  : breadcrumb([
      { name: zh ? '首页' : 'Home', url: zh ? site + '/' : site + '/en/' },
      { name: page.llms?.label ?? page.title, url: canonical },
    ]);
const ogImage = site + '/og-banner.png';
// API 接口为第一方 API 子域外链(业务侧指定 2026-06-12);其余为站内页
const nav = zh
  ? [
      { href: '/', label: '首页' },
      { href: '/zh/sma', label: '产品' },
      { href: '/zh/what-is-llm-gateway', label: '什么是 LLM 网关' },
      { href: '/zh/faq', label: 'FAQ' },
      { href: 'https://api.smaapi.com', label: 'API 接口', external: true },
    ]
  : [
      { href: '/en/', label: 'Home' },
      { href: '/en/sma', label: 'Product' },
      { href: '/en/what-is-llm-gateway', label: 'What is an LLM gateway' },
      { href: '/en/faq', label: 'FAQ' },
      { href: 'https://api.smaapi.com', label: 'API', external: true },
    ];
---

<!doctype html>
<html lang={zh ? 'zh-CN' : 'en'}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{page.title}</title>
    <meta name="description" content={page.description} />
    <link rel="canonical" href={canonical} />
    <link rel="alternate" hreflang={zh ? 'zh-CN' : 'en'} href={canonical} />
    {alt && <link rel="alternate" hreflang={zh ? 'en' : 'zh-CN'} href={site + alt.route} />}
    <link rel="alternate" hreflang="x-default" href={xDefault} />
    <meta property="og:title" content={page.title} />
    <meta property="og:description" content={page.description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content={zh ? 'zh_CN' : 'en_US'} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="SMA — 企业级 AI 网关 / Enterprise AI Gateway" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={ogImage} />
    <script type="application/ld+json" set:html={JSON.stringify(organization)} />
    <script type="application/ld+json" set:html={JSON.stringify(website)} />
    {crumb && <script type="application/ld+json" set:html={JSON.stringify(crumb)} />}
    <slot name="jsonld" />
  </head>
  <body class={isDark ? 'theme-dark' : undefined}>
    <header>
      <nav>
        <a class="brand" href={zh ? '/' : '/en/'}>
          <Logo size={26} eager light={isDark} />
          <span>{zh ? '菌路 SMA' : 'smaapi Gateway'}</span>
        </a>
        {nav.map((item) =>
          item.external ? (
            <a class="nav-api" href={item.href} target="_blank" rel="noopener">{item.label}<span class="ext" aria-hidden="true">↗</span></a>
          ) : (
            <a href={item.href} aria-current={item.href === route ? 'page' : undefined}>
              {item.label}
            </a>
          )
        )}
        {alt && <a class="lang-switch" href={alt.route}>{zh ? 'English' : '中文'}</a>}
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer>
      <div class="foot-brand">
        <Logo size={22} light={isDark} />
        <p class="slogans">
          <span class="slogan-zh">数据可控,为每个任务选择最合适的模型。</span>
          <span class="slogan-en">Enterprise-controlled access — the right model for every task.</span>
        </p>
      </div>
      <p>
        {zh ? '更新于' : 'Last updated'} {page.dateModified} · © 2026 {zh ? '菌路科技' : 'Slime Mould Tech'}
      </p>
      <p class="disclaimer">
        {zh
          ? 'OpenAI、Anthropic、Google 为各商标持有人,本平台与上述公司无官方合作关系(如有变更以公告为准)。模型名称仅为指明性使用。'
          : 'OpenAI, Anthropic, and Google are trademarks of their respective holders. This platform has no official affiliation with these companies (subject to change by announcement). Model names are used nominatively.'}
      </p>
    </footer>
  </body>
</html>

<style is:global>
  :root {
    /* 品牌色系(菌路 Logo 设计说明 §4):深绿核心 + 白负空间 + 浅/深底 */
    --core: #123c34;
    --fg: #15231e;
    --muted: #4c5f58;
    --line: #dde7e2;
    --accent: #1d5c49;
    --soft: #f8faf7;
    --dark: #07130f;
    --node: #2f7d5e;
  }
  * {
    box-sizing: border-box;
  }
  @media (prefers-reduced-motion: no-preference) {
    html {
      scroll-behavior: smooth;
    }
  }
  [id] {
    scroll-margin-top: 4.25rem;
  }
  ::selection {
    background: #bff0d9;
    color: #0b211a;
  }
  body {
    margin: 0;
    color: var(--fg);
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB',
      'Microsoft YaHei', sans-serif;
    line-height: 1.7;
    -webkit-font-smoothing: antialiased;
  }
  :focus-visible {
    outline: 2px solid var(--node);
    outline-offset: 2px;
    border-radius: 3px;
  }
  header nav,
  main,
  footer .foot-brand,
  footer p {
    max-width: 760px;
    margin: 0 auto;
    padding: 0 1.25rem;
  }
  header {
    position: sticky;
    top: 0;
    z-index: 20;
    border-bottom: 1px solid var(--line);
    background: rgba(255, 255, 255, 0.88);
    -webkit-backdrop-filter: blur(10px);
    backdrop-filter: blur(10px);
  }
  header nav {
    display: flex;
    gap: 1rem;
    align-items: center;
    padding-top: 0.6rem;
    padding-bottom: 0.6rem;
    flex-wrap: wrap;
  }
  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: 700;
    color: var(--core);
  }
  .brand:hover {
    text-decoration: none;
  }
  .brand svg {
    display: block;
  }
  .lang-switch {
    margin-left: auto;
  }
  header nav a[aria-current='page'] {
    color: var(--core);
    font-weight: 600;
  }
  a {
    color: var(--accent);
    text-decoration: none;
    transition: color 0.15s ease;
  }
  a:hover {
    text-decoration: underline;
  }
  main {
    padding-top: 1.5rem;
    padding-bottom: 3rem;
  }
  h1 {
    line-height: 1.3;
  }
  h2 {
    color: var(--core);
    margin-top: 2.6rem;
    line-height: 1.35;
  }
  .answer {
    border-left: 4px solid var(--accent);
    background: var(--soft);
    padding: 0.75rem 1rem;
    margin: 1rem 0 2rem;
    font-size: 1.05rem;
  }
  table {
    border-collapse: collapse;
    width: 100%;
    margin: 1rem 0;
  }
  th,
  td {
    border: 1px solid var(--line);
    padding: 0.5rem 0.75rem;
    text-align: left;
    vertical-align: top;
  }
  th {
    background: var(--soft);
  }
  footer {
    border-top: 1px solid var(--line);
    background: var(--soft);
    color: var(--muted);
    font-size: 0.9rem;
  }
  footer .foot-brand {
    display: flex;
    align-items: flex-start;
    gap: 0.6rem;
    padding-top: 1.25rem;
  }
  footer .foot-brand svg {
    flex: none;
    margin-top: 0.2rem;
  }
  .slogans {
    margin: 0;
  }
  .slogans span {
    display: block;
  }
  .slogan-zh {
    color: var(--core);
    font-weight: 600;
  }
  .slogan-en {
    font-size: 0.85rem;
    letter-spacing: 0.01em;
  }
  footer p {
    padding-top: 1rem;
    padding-bottom: 1rem;
  }
  footer .disclaimer {
    padding-top: 0;
    font-size: 0.8rem;
    opacity: 0.85;
  }
  .related {
    margin-top: 2.5rem;
    border-top: 1px solid var(--line);
    padding-top: 1rem;
  }
  .footnote {
    font-size: 0.85rem;
    color: var(--muted);
  }
  pre {
    background: var(--dark);
    color: #d9efe4;
    padding: 1rem 1.25rem;
    border-radius: 10px;
    overflow-x: auto;
    font-size: 0.88rem;
    line-height: 1.6;
  }
  pre code {
    background: none;
    padding: 0;
  }
  code {
    background: var(--soft);
    padding: 0.1em 0.35em;
    border-radius: 4px;
    font-size: 0.92em;
  }
  .nav-api {
    display: inline-flex;
    align-items: center;
    gap: 1px;
    padding: 0.12rem 0.62rem;
    border: 1px solid var(--line);
    border-radius: 999px;
    font-weight: 600;
  }
  .nav-api:hover {
    text-decoration: none;
    border-color: var(--accent);
  }
  .nav-api .ext {
    font-size: 0.8em;
    opacity: 0.7;
  }

  /* ===== 暗色科技主题(仅首页 body.theme-dark;站内内容页保持浅色) ===== */
  body.theme-dark {
    color: #dfeee8;
    background-color: #060f12;
    background-image:
      radial-gradient(rgba(120, 200, 175, 0.045) 1px, transparent 1.5px),
      radial-gradient(60% 48% at 86% 0%, rgba(215, 166, 66, 0.1), transparent 60%),
      radial-gradient(52% 44% at 2% 10%, rgba(34, 110, 96, 0.16), transparent 55%),
      linear-gradient(180deg, #08161b 0%, #060f12 58%);
    background-size: 24px 24px, auto, auto, auto;
    background-attachment: fixed;
  }
  body.theme-dark header nav,
  body.theme-dark main,
  body.theme-dark footer .foot-brand,
  body.theme-dark footer p {
    max-width: 960px;
  }
  body.theme-dark header {
    background: rgba(8, 18, 20, 0.72);
    border-bottom-color: rgba(120, 180, 160, 0.14);
  }
  body.theme-dark .brand {
    color: #eaf3ef;
  }
  body.theme-dark a {
    color: #84dcb6;
  }
  body.theme-dark main a {
    color: #f2c75c;
  }
  body.theme-dark header nav a {
    color: #c9e0d6;
  }
  body.theme-dark header nav a:hover {
    color: #fff;
  }
  body.theme-dark header nav a[aria-current='page'] {
    color: #f2c75c;
  }
  body.theme-dark .nav-api {
    color: #f2c75c;
    border-color: rgba(242, 199, 92, 0.4);
    background: rgba(242, 199, 92, 0.08);
  }
  body.theme-dark .nav-api:hover {
    border-color: rgba(242, 199, 92, 0.75);
  }
  body.theme-dark h1,
  body.theme-dark h2 {
    color: #fff;
  }
  body.theme-dark .answer {
    background: rgba(215, 166, 66, 0.06);
    border-left-color: #f2c75c;
    color: #eef6f1;
  }
  body.theme-dark code {
    background: rgba(255, 255, 255, 0.08);
    color: #d9efe4;
  }
  body.theme-dark .related {
    border-top-color: rgba(120, 180, 160, 0.14);
  }
  body.theme-dark .footnote {
    color: #8aa79b;
  }
  body.theme-dark footer {
    background: rgba(8, 18, 20, 0.55);
    border-top-color: rgba(120, 180, 160, 0.12);
    color: #9fb8ad;
  }
  body.theme-dark .slogan-zh {
    color: #ffe6a8;
  }
  body.theme-dark :focus-visible {
    outline-color: #f2c75c;
  }
  body.theme-dark ::selection {
    background: rgba(242, 199, 92, 0.32);
    color: #fff;
  }

  /* ===== 暗色页内容版式(首页 / 产品页共用:分节 eyebrow + 面板 + 卡片 + 终端 + 科学家) ===== */
  body.theme-dark .band {
    margin: 2.4rem 0;
  }
  body.theme-dark .eyebrow {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    margin: 0 0 0.3rem;
    font-size: 0.74rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #84dcb6;
    font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
  }
  body.theme-dark .eyebrow-no {
    color: #f2c75c;
  }
  body.theme-dark .eyebrow::after {
    content: '';
    flex: 1;
    height: 1px;
    background: linear-gradient(90deg, rgba(132, 220, 182, 0.4), transparent);
  }
  body.theme-dark .band h2 {
    margin-top: 0.1rem;
  }
  body.theme-dark .trust {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(218px, 1fr));
    gap: 0.9rem;
    margin: 1.1rem 0 0.5rem;
  }
  body.theme-dark .trust-card {
    position: relative;
    overflow: hidden;
    border: 1px solid rgba(140, 200, 180, 0.14);
    border-top: 2px solid rgba(242, 199, 92, 0.55);
    border-radius: 14px;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.05), rgba(255, 255, 255, 0.02));
    padding: 1.05rem 1.2rem 1.15rem;
    -webkit-backdrop-filter: blur(6px);
    backdrop-filter: blur(6px);
  }
  @media (hover: hover) {
    body.theme-dark .trust-card {
      transition: transform 0.18s ease, box-shadow 0.18s ease, border-color 0.18s ease;
    }
    body.theme-dark .trust-card:hover {
      transform: translateY(-3px);
      border-top-color: #f2c75c;
      box-shadow: 0 14px 32px rgba(4, 10, 11, 0.5), 0 0 0 1px rgba(242, 199, 92, 0.12);
    }
  }
  body.theme-dark .trust-num {
    position: absolute;
    top: -0.2rem;
    right: 0.6rem;
    font-size: 3.2rem;
    font-weight: 800;
    line-height: 1.4;
    color: rgba(242, 199, 92, 0.12);
    pointer-events: none;
    user-select: none;
  }
  body.theme-dark .trust-card h3 {
    margin: 0.3rem 0 0.45rem;
    color: #fff;
  }
  body.theme-dark .trust-card p {
    margin: 0;
    color: #c4d8ce;
    font-size: 0.94rem;
  }
  body.theme-dark .trust-tag {
    font-size: 0.76rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    color: #84dcb6;
  }
  body.theme-dark .codeblock {
    margin: 1rem 0;
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid rgba(140, 200, 180, 0.18);
    box-shadow: 0 14px 34px rgba(4, 10, 11, 0.5);
  }
  body.theme-dark .codeblock figcaption {
    display: flex;
    align-items: center;
    gap: 0.42rem;
    padding: 0.55rem 1rem;
    background: #0c1f1a;
    border-bottom: 1px solid rgba(95, 214, 163, 0.16);
  }
  body.theme-dark .codeblock .dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
  }
  body.theme-dark .codeblock .d1 { background: #c0703a; }
  body.theme-dark .codeblock .d2 { background: #d7a642; }
  body.theme-dark .codeblock .d3 { background: #5fd6a3; }
  body.theme-dark .codeblock .codefile {
    margin-left: auto;
    font-size: 0.78rem;
    color: #9fc7b6;
    font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
  }
  body.theme-dark .codeblock pre {
    margin: 0;
    border-radius: 0;
    background: #07130f;
  }
  body.theme-dark .codeblock .k { color: #f2c75c; }
  body.theme-dark .codeblock .s { color: #b6f5d8; }
  body.theme-dark .codeblock .c { color: #6f8d80; }
  body.theme-dark .scientist {
    position: relative;
    overflow: hidden;
    margin-top: 1.1rem;
    border: 1px solid rgba(140, 200, 180, 0.16);
    border-radius: 16px;
    padding: 1.5rem 1.6rem;
    background:
      radial-gradient(70% 120% at 100% 0%, rgba(215, 166, 66, 0.1), transparent 55%),
      linear-gradient(180deg, rgba(255, 255, 255, 0.05), rgba(255, 255, 255, 0.018));
    -webkit-backdrop-filter: blur(6px);
    backdrop-filter: blur(6px);
    box-shadow: 0 16px 40px rgba(4, 10, 11, 0.4);
  }
  body.theme-dark .sci-head {
    display: flex;
    gap: 1rem;
    align-items: center;
  }
  body.theme-dark .sci-mono {
    flex: none;
    display: grid;
    place-items: center;
    width: 60px;
    height: 60px;
    border-radius: 16px;
    background: linear-gradient(160deg, #f2c75c, #d7a642);
    color: #1a1205;
    font-weight: 800;
    font-size: 1.7rem;
    box-shadow: 0 8px 22px rgba(215, 166, 66, 0.3);
  }
  body.theme-dark .sci-name {
    margin: 0;
    color: #fff;
    font-size: 1.25rem;
  }
  body.theme-dark .sci-role {
    margin-left: 0.4rem;
    padding: 0.12rem 0.55rem;
    border-radius: 999px;
    background: rgba(242, 199, 92, 0.14);
    border: 1px solid rgba(242, 199, 92, 0.4);
    color: #f2c75c;
    font-size: 0.74rem;
    font-weight: 600;
    vertical-align: middle;
  }
  body.theme-dark .sci-titles {
    margin: 0.35rem 0 0;
    color: #c4d8ce;
    font-size: 0.9rem;
    line-height: 1.55;
  }
  body.theme-dark .sci-stats {
    display: flex;
    flex-wrap: wrap;
    gap: 0.7rem;
    margin: 1.2rem 0;
  }
  body.theme-dark .sci-stat {
    flex: 1 1 140px;
    border: 1px solid rgba(140, 200, 180, 0.14);
    border-radius: 12px;
    padding: 0.7rem 0.9rem;
    background: rgba(255, 255, 255, 0.025);
  }
  body.theme-dark .sci-stat-n {
    display: block;
    font-size: 1.4rem;
    font-weight: 800;
    color: #f2c75c;
    line-height: 1.2;
    font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
  }
  body.theme-dark .sci-stat-l {
    display: block;
    margin-top: 0.15rem;
    font-size: 0.78rem;
    color: #9fb8ad;
  }
  body.theme-dark .sci-bio {
    margin: 0 0 1rem;
    color: #cbddd3;
    font-size: 0.95rem;
  }
  body.theme-dark .sci-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1.1rem;
  }
  body.theme-dark .sci-tag {
    padding: 0.28rem 0.7rem;
    border: 1px solid rgba(140, 200, 180, 0.2);
    border-radius: 999px;
    background: rgba(132, 220, 182, 0.07);
    color: #bfe6d6;
    font-size: 0.78rem;
  }
  body.theme-dark .sci-research {
    margin: 0;
    padding: 0.8rem 1rem;
    border-left: 3px solid #f2c75c;
    border-radius: 0 10px 10px 0;
    background: rgba(242, 199, 92, 0.07);
    color: #eaf3ef;
    font-size: 0.95rem;
  }
  body.theme-dark .sci-research-k {
    display: inline-block;
    margin-right: 0.55rem;
    color: #f2c75c;
    font-weight: 700;
    font-size: 0.82rem;
    letter-spacing: 0.04em;
  }
</style>

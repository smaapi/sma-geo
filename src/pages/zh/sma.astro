---
import Base from '../../layouts/Base.astro';
import { softwareApplication, chiefScientist } from '../../lib/schema';

// 接入示例:静态语法着色(无运行时 JS)
const codeHtml = [
  '<span class="k">from</span> openai <span class="k">import</span> OpenAI',
  '',
  'client = OpenAI(',
  '    base_url=<span class="s">"https://www.smaapi.com/v1"</span>,  <span class="c"># 指向 SMA 网关</span>',
  '    api_key=<span class="s">"YOUR_SMA_KEY"</span>,                <span class="c"># 网关密钥,模型厂商密钥不出企业</span>',
  ')',
  '',
  'resp = client.chat.completions.create(',
  '    model=<span class="s">"deepseek-chat"</span>,  <span class="c"># 模型名按路由策略可换可路由</span>',
  '    messages=[{<span class="s">"role"</span>: <span class="s">"user"</span>, <span class="s">"content"</span>: <span class="s">"你好"</span>}],',
  ')',
].join('\n');

const sciStats = [
  { n: '100+', l: '学术论文 · 顶会/权威期刊' },
  { n: '100+', l: 'CCF-A 论文 · 一作/通讯' },
  { n: '2.1万+', l: 'Google Scholar 引用' },
];
const sciTags = [
  '国家优青',
  'IEEE TIP 编委',
  'AAAI · IJCAI · CIKM · ACM MM 领域主席',
  '上海市科技进步特等奖',
  'CSIG 科技进步一等奖',
];
const toc = [
  { href: '#problem', label: '解决的问题' },
  { href: '#governance', label: '三层治理' },
  { href: '#capabilities', label: '能力全景' },
  { href: '#integrate', label: '接入' },
  { href: '#team', label: '团队' },
  { href: '#who', label: '适用对象' },
];
---

<Base route="/zh/sma" theme="dark">
  <script slot="jsonld" type="application/ld+json" set:html={JSON.stringify(softwareApplication)} />
  <script slot="jsonld" type="application/ld+json" set:html={JSON.stringify(chiefScientist)} />

  <section class="page-head">
    <p class="eyebrow"><span class="eyebrow-no">SMA</span> 产品介绍</p>
    <h1>SMA — 企业级 AI 网关</h1>
    <p class="answer">
      SMA 网关(菌路 SMA,www.smaapi.com)是面向企业的 AI 网关 / 模型接入平台:以一套 OpenAI 兼容 API
      统一接入多家大模型,提供智能路由、成本与权限治理、全链路审计,让企业可控地使用多模型能力。
    </p>
    <nav class="toc" aria-label="本页目录">
      {toc.map((t) => <a href={t.href}>{t.label}</a>)}
    </nav>
  </section>

  <section class="band" id="problem">
    <p class="eyebrow"><span class="eyebrow-no">01</span> 问题</p>
    <h2>SMA 解决什么问题?</h2>
    <p>
      多模型并存已是企业用 AI 的常态:不同任务适合不同模型,供应商各有独立的接口、密钥和计费体系。直接逐家接入的结果是密钥散落在各处、成本没有统一口径、调用无法审计、切换供应商要改代码。SMA
      在企业应用与模型供应商之间加一层统一的接入与治理层,把这些问题收敛到一个出口。
    </p>
  </section>

  <section class="band" id="governance">
    <p class="eyebrow"><span class="eyebrow-no">02</span> 治理</p>
    <h2>三层治理,三层可信度</h2>
    <p>
      网关的价值不止于"接得上",更在于"敢交给它"。SMA 的三层能力,对应企业信任一套 AI 基础设施所需的三层证据:
    </p>
    <div class="trust">
      <div class="trust-card">
        <span class="trust-num" aria-hidden="true">01</span>
        <span class="trust-tag">第一层 · 路由可信</span>
        <h3>智能路由</h3>
        <p>
          按请求的业务特征与各模型的实时状态(可用性、延迟、成本)分发流量,支持企业策略约束与人工校准;模型故障时自动降级与切换,对应用透明。路由决策有据可查,而非黑箱。
        </p>
      </div>
      <div class="trust-card">
        <span class="trust-num" aria-hidden="true">02</span>
        <span class="trust-tag">第二层 · 边界可信</span>
        <h3>成本与权限治理</h3>
        <p>
          为团队、应用、密钥设置预算、配额与模型访问范围;所有调用统一计量,成本可按维度核算,密钥集中管理而非散落在业务代码里。花了多少、谁能用什么,边界由企业自己划定。
        </p>
      </div>
      <div class="trust-card">
        <span class="trust-num" aria-hidden="true">03</span>
        <span class="trust-tag">第三层 · 留痕可信</span>
        <h3>全链路审计</h3>
        <p>
          每一次调用的调用方、目标模型、用量与时间都进入审计日志,可追溯、可对账,为合规审查提供完整证据链。事后任何一笔调用都经得起回放与质询。
        </p>
      </div>
    </div>
  </section>

  <section class="band" id="capabilities">
    <p class="eyebrow"><span class="eyebrow-no">03</span> 能力</p>
    <h2>能力全景</h2>
    <p>
      SMA 的能力按形态划分:软件 / API 层随接入即用,硬件 / SMA Edge 层作为更高可用与私有化的升级形态。
    </p>
    <h3>软件 / API 层(随接入即用)</h3>
    <ul>
      <li><strong>统一接入:</strong>一套 OpenAI 兼容 API 接入多家国产与国际模型,应用只改 base_url。</li>
      <li><strong>智能路由:</strong>按任务特征与难度分级路由——简单任务走更快更省的模型、复杂任务走能力更强的模型,代码任务进代码通道。</li>
      <li><strong>可解释路由:</strong>候选模型、质量门槛与排除原因都可查,路由不是黑箱。</li>
      <li><strong>数据安全:</strong>出口侧对个人信息与中文敏感实体脱敏(Token Vault),明文不外发、不进审计。</li>
      <li><strong>内容安全策略:</strong>企业红线在网关侧统一执行,命中即阻断、不调用外部模型。</li>
      <li><strong>高可用与故障切换:</strong>按错误类型自动切换到候选模型,以状态续接保留上下文,切换对应用透明。<a href="/zh/overseas-llm-high-availability">详见高可用接入 →</a></li>
      <li><strong>成本与权限治理:</strong>为团队 / 应用 / 密钥设预算、配额与限流,统一计量,可按密钥 · 项目 · 模型对账。<a href="/zh/llm-cost-governance">详见成本治理 →</a></li>
      <li><strong>全链路审计:</strong>每次调用的调用方、目标模型、用量与时间留痕,可追溯、可对账。</li>
      <li><strong>模型校准与评估:</strong>用客户自己的任务集校准模型能力,让选型有据可依。</li>
    </ul>
    <h3>硬件 / SMA Edge 层(升级形态)</h3>
    <ul>
      <li><strong>主动健康监控:</strong>对模型端点的实时运行状态持续监控、支持预判式切换;此项需配合 SMA 网关硬件。</li>
      <li><strong>私有化部署:</strong>网关运行在企业自有环境,提示词、密钥与日志不出企业边界,适合强合规场景。</li>
    </ul>
    <p class="footnote">
      能力以产品实际配置与合同条款为准;主动健康监控与私有化(数据不出域)为 SMA Edge 硬件形态提供。海外模型合规接入见<a href="/zh/compliant-overseas-llm-access">合规接入指南</a>。
    </p>
  </section>

  <section class="band" id="integrate">
    <p class="eyebrow"><span class="eyebrow-no">04</span> 接入</p>
    <h2>接入只改一行配置</h2>
    <p>应用侧沿用 OpenAI SDK,把 <code>base_url</code> 指向网关即可:</p>
    <figure class="codeblock">
      <figcaption>
        <span class="dot d1"></span><span class="dot d2"></span><span class="dot d3"></span>
        <span class="codefile">app.py</span>
      </figcaption>
      <pre><code set:html={codeHtml} /></pre>
    </figure>
    <p class="footnote">模型名称为指明性使用;可接入模型范围与路由策略以控制台实际配置为准。</p>
  </section>

  <section class="band" id="team">
    <p class="eyebrow"><span class="eyebrow-no">05</span> 团队</p>
    <h2>首席科学家</h2>
    <div class="scientist">
      <div class="sci-head">
        <span class="sci-mono" aria-hidden="true">谢</span>
        <div class="sci-id">
          <p class="sci-name"><strong>谢源</strong> <span class="sci-role">首席科学家</span></p>
          <p class="sci-titles">
            华东师范大学计算机科学与技术学院 教授 · 国家人工智能学院(上海)全时导师 · 博士生导师
          </p>
        </div>
      </div>

      <div class="sci-stats">
        {sciStats.map((s) => (
          <div class="sci-stat">
            <span class="sci-stat-n">{s.n}</span>
            <span class="sci-stat-l">{s.l}</span>
          </div>
        ))}
      </div>

      <p class="sci-bio">
        先后主持科技部科技创新 2030"新一代人工智能"重大项目课题、国家自然科学基金等国家级科研项目。在国内外权威期刊和顶级会议上共发表学术论文百余篇,其中第一作者/通讯作者
        CCF A 类论文百余篇,相关成果 Google Scholar 引用逾 2.1 万次。
      </p>

      <div class="sci-tags">
        {sciTags.map((t) => <span class="sci-tag">{t}</span>)}
      </div>

      <p class="sci-research">
        <span class="sci-research-k">研究方向</span>大模型持续学习与持续进化智能体——与 SMA 的记忆沉淀、路由校准设计高度相关。
      </p>
    </div>
  </section>

  <section class="band" id="who">
    <p class="eyebrow"><span class="eyebrow-no">06</span> 适用</p>
    <h2>谁适合使用 SMA?</h2>
    <p>
      需要同时接入多家模型(含国产模型与国际模型)、并对成本、权限、合规与审计有组织级要求的企业团队。应用侧沿用
      OpenAI SDK,把 base_url 指向网关即可接入。
    </p>
  </section>

  <div class="related">
    <p>相关问题:</p>
    <ul>
      <li><a href="/zh/compliant-overseas-llm-access">企业如何合规接入海外大模型?</a></li>
      <li><a href="/zh/llm-cost-governance">多团队大模型成本与权限治理</a></li>
      <li><a href="/zh/overseas-llm-high-availability">海外大模型高可用接入</a></li>
      <li><a href="/zh/what-is-llm-gateway">什么是企业级 LLM 网关?</a></li>
      <li><a href="/zh/faq">多模型接入、路由与治理的常见问题</a></li>
    </ul>
  </div>
</Base>

<style>
  .page-head {
    margin: 0.5rem 0 1rem;
  }
  .page-head h1 {
    margin: 0.4rem 0 0.6rem;
    color: #fff;
    font-size: 1.9rem;
    line-height: 1.25;
  }
  .toc {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 1.1rem;
  }
  .toc a {
    padding: 0.32rem 0.85rem;
    border: 1px solid rgba(140, 200, 180, 0.22);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.03);
    color: #cfe6db;
    font-size: 0.85rem;
  }
  .toc a:hover {
    text-decoration: none;
    border-color: rgba(242, 199, 92, 0.6);
    color: #f2c75c;
  }
</style>

---
import Base from '../layouts/Base.astro';
import { softwareApplication } from '../lib/schema';
import RouteCore from '../components/RouteCore.astro';
---

<Base route="/" theme="dark">
  <script slot="jsonld" type="application/ld+json" set:html={JSON.stringify(softwareApplication)} />

  <section class="landing">
    <div class="landing-fx" aria-hidden="true"></div>
    <div class="landing-inner">
      <span class="hero-chip"><span class="chip-dot"></span>智能路由 · 系统运行中</span>
      <div class="landing-core">
        <RouteCore size={360} class="landing-core-viz" />
      </div>
      <h1>SMA — 企业级 AI 网关</h1>
      <p class="landing-slogan">寻最优之路，铸不变之稳。</p>
      <p class="landing-slogan-en">Always optimal, always stable.</p>
      <p class="landing-def">
        SMA 网关(菌路 SMA)是面向企业的 AI 网关 / 模型接入平台:一套 OpenAI 兼容 API 统一接入多家大模型,提供智能路由、成本与权限治理与全链路审计。
      </p>
      <div class="landing-cta">
        <a class="btn btn-solid" href="/zh/sma">了解 SMA 产品</a>
        <a class="btn btn-ghost" href="/zh/what-is-llm-gateway">什么是 LLM 网关</a>
      </div>
    </div>
  </section>
</Base>

<style>
  /* —— 极简电影感落地页:满屏暗底 + 金色寻路核心居中 —— */
  .landing {
    position: relative;
    overflow: hidden;
    min-height: calc(100vh - 3.6rem);
    display: grid;
    place-items: center;
    margin: -1.5rem 0 0;
    padding: 1.5rem 0 3rem;
    text-align: center;
  }
  .landing-fx {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      radial-gradient(46% 40% at 50% 38%, rgba(215, 166, 66, 0.16), transparent 62%),
      radial-gradient(60% 50% at 50% 120%, rgba(34, 110, 96, 0.16), transparent 60%);
    -webkit-mask-image: radial-gradient(80% 70% at 50% 42%, #000 40%, transparent 85%);
    mask-image: radial-gradient(80% 70% at 50% 42%, #000 40%, transparent 85%);
  }
  .landing-inner {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    max-width: 680px;
  }
  .hero-chip {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.3rem 0.8rem;
    border: 1px solid rgba(215, 166, 66, 0.4);
    border-radius: 999px;
    background: rgba(215, 166, 66, 0.08);
    color: #f2c75c;
    font-size: 0.76rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
  }
  .chip-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: #f2c75c;
    box-shadow: 0 0 0 0 rgba(242, 199, 92, 0.6);
    animation: chipPulse 2.4s ease-out infinite;
  }
  @keyframes chipPulse {
    0% { box-shadow: 0 0 0 0 rgba(242, 199, 92, 0.55); }
    70%, 100% { box-shadow: 0 0 0 8px rgba(242, 199, 92, 0); }
  }
  .landing-core {
    margin: 1rem 0 0.5rem;
  }
  .landing-core :global(.landing-core-viz) {
    filter: drop-shadow(0 0 40px rgba(215, 166, 66, 0.28));
  }
  .landing h1 {
    margin: 0.4rem 0 0.6rem;
    color: #fff;
    font-size: 2.4rem;
    line-height: 1.2;
    letter-spacing: 0.01em;
  }
  .landing-slogan {
    margin: 0;
    font-weight: 600;
    font-size: 1.12rem;
    color: #ffe6a8;
  }
  .landing-slogan-en {
    margin: 0.3rem 0 0;
    font-size: 0.86rem;
    color: #93bdab;
    font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
  }
  .landing-def {
    margin: 1.1rem 0 0;
    max-width: 560px;
    font-size: 0.95rem;
    line-height: 1.65;
    color: #b9cfc6;
  }
  .landing-cta {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    justify-content: center;
    margin-top: 1.8rem;
  }
  .btn {
    display: inline-block;
    padding: 0.62rem 1.4rem;
    border-radius: 10px;
    font-size: 0.95rem;
    font-weight: 600;
    line-height: 1.5;
    transition: background 0.15s ease, border-color 0.15s ease, color 0.15s ease, box-shadow 0.15s ease;
  }
  .btn:hover {
    text-decoration: none;
  }
  .btn-solid {
    background: linear-gradient(180deg, #f2c75c, #d7a642);
    color: #1a1205;
    box-shadow: 0 6px 20px rgba(215, 166, 66, 0.3);
  }
  .btn-solid:hover {
    background: linear-gradient(180deg, #f6d271, #e0b14e);
  }
  .btn-ghost {
    border: 1px solid rgba(174, 244, 212, 0.34);
    color: #d3efe1;
  }
  .btn-ghost:hover {
    border-color: rgba(174, 244, 212, 0.7);
    color: #fff;
  }
  @media (max-width: 600px) {
    .landing h1 {
      font-size: 1.85rem;
    }
    .landing-core :global(.landing-core-viz) {
      width: 264px !important;
      height: 264px !important;
    }
  }
</style>

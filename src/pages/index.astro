---
import Base from '../layouts/Base.astro';
import { softwareApplication } from '../lib/schema';
import RouteCore from '../components/RouteCore.astro';

// 接入示例:静态语法着色(无运行时 JS;set:html 注入,token 样式走 :global)
const codeHtml = [
  '<span class="k">from</span> openai <span class="k">import</span> OpenAI',
  '',
  'client = OpenAI(',
  '    base_url=<span class="s">"https://www.smaapi.com/v1"</span>,  <span class="c"># 指向 SMA 网关</span>',
  '    api_key=<span class="s">"YOUR_SMA_KEY"</span>,                <span class="c"># 网关密钥,模型厂商密钥不出企业</span>',
  ')',
  '',
  'resp = client.chat.completions.create(',
  '    model=<span class="s">"deepseek-chat"</span>,  <span class="c"># 模型名按路由策略可换可路由</span>',
  '    messages=[{<span class="s">"role"</span>: <span class="s">"user"</span>, <span class="s">"content"</span>: <span class="s">"你好"</span>}],',
  ')',
].join('\n');
---

<Base route="/">
  <script slot="jsonld" type="application/ld+json" set:html={JSON.stringify(softwareApplication)} />

  <section class="hero">
    <div class="hero-fx" aria-hidden="true"></div>
    <div class="hero-inner">
      <div class="hero-copy">
        <span class="hero-chip"><span class="chip-dot"></span>智能路由 · 系统运行中</span>
        <h1>SMA — 企业级 AI 网关</h1>
        <p class="hero-slogan">数据可控,为每个任务选择最合适的模型。</p>
        <p class="hero-slogan-en">Enterprise-controlled access — the right model for every task.</p>
        <div class="hero-cta">
          <a class="btn btn-solid" href="#integrate">查看接入示例</a>
          <a class="btn btn-ghost" href="/zh/what-is-llm-gateway">什么是 LLM 网关</a>
        </div>
      </div>
      <div class="hero-core">
        <RouteCore size={340} class="hero-core-viz" />
        <p class="hero-core-cap"><b>智能路由核心</b> · 真菌寻路 · <span class="cap-on">持续探索最优路径</span></p>
      </div>
    </div>
  </section>

  <p class="answer">
    SMA 网关(菌路 SMA,www.smaapi.com)是面向企业的 AI 网关 / 模型接入平台:以一套 OpenAI 兼容 API
    统一接入多家大模型,提供智能路由、成本与权限治理、全链路审计,让企业可控地使用多模型能力。
  </p>

  <h2>SMA 解决什么问题?</h2>
  <p>
    多模型并存已是企业用 AI 的常态:不同任务适合不同模型,供应商各有独立的接口、密钥和计费体系。直接逐家接入的结果是密钥散落在各处、成本没有统一口径、调用无法审计、切换供应商要改代码。SMA
    在企业应用与模型供应商之间加一层统一的接入与治理层,把这些问题收敛到一个出口。
  </p>

  <h2>三层治理,三层可信度</h2>
  <p>
    网关的价值不止于"接得上",更在于"敢交给它"。SMA 的三层能力,对应企业信任一套 AI 基础设施所需的三层证据:
  </p>
  <div class="trust">
    <div class="trust-card">
      <span class="trust-num" aria-hidden="true">01</span>
      <span class="trust-tag">第一层 · 路由可信</span>
      <h3>智能路由</h3>
      <p>
        按请求的业务特征与各模型的实时状态(可用性、延迟、成本)分发流量,支持企业策略约束与人工校准;模型故障时自动降级与切换,对应用透明。路由决策有据可查,而非黑箱。
      </p>
    </div>
    <div class="trust-card">
      <span class="trust-num" aria-hidden="true">02</span>
      <span class="trust-tag">第二层 · 边界可信</span>
      <h3>成本与权限治理</h3>
      <p>
        为团队、应用、密钥设置预算、配额与模型访问范围;所有调用统一计量,成本可按维度核算,密钥集中管理而非散落在业务代码里。花了多少、谁能用什么,边界由企业自己划定。
      </p>
    </div>
    <div class="trust-card">
      <span class="trust-num" aria-hidden="true">03</span>
      <span class="trust-tag">第三层 · 留痕可信</span>
      <h3>全链路审计</h3>
      <p>
        每一次调用的调用方、目标模型、用量与时间都进入审计日志,可追溯、可对账,为合规审查提供完整证据链。事后任何一笔调用都经得起回放与质询。
      </p>
    </div>
  </div>

  <h2 id="integrate">接入只改一行配置</h2>
  <p>应用侧沿用 OpenAI SDK,把 <code>base_url</code> 指向网关即可:</p>
  <figure class="codeblock">
    <figcaption>
      <span class="dot d1"></span><span class="dot d2"></span><span class="dot d3"></span>
      <span class="codefile">app.py</span>
    </figcaption>
    <pre><code set:html={codeHtml} /></pre>
  </figure>
  <p class="footnote">模型名称为指明性使用;可接入模型范围与路由策略以控制台实际配置为准。</p>

  <h2>学术顾问</h2>
  <div class="advisor">
    <span class="advisor-mono" aria-hidden="true">谢</span>
    <div>
      <p class="advisor-name"><strong>谢源 教授</strong> · 学术顾问</p>
      <p>
        研究关注持续学习与企业 AI 系统。在 SMA,他关注的核心命题是"记忆归企业"——模型可以替换,但企业的使用记忆、路由经验与治理规则,应当沉淀在企业自己手里。这一命题贯穿
        SMA 的路由校准与审计设计。
      </p>
    </div>
  </div>

  <h2>谁适合使用 SMA?</h2>
  <p>
    需要同时接入多家模型(含国产模型与国际模型)、并对成本、权限、合规与审计有组织级要求的企业团队。应用侧沿用
    OpenAI SDK,把 base_url 指向网关即可接入。
  </p>

  <div class="related">
    <p>相关问题:</p>
    <ul>
      <li><a href="/zh/what-is-llm-gateway">什么是企业级 LLM 网关?</a></li>
      <li><a href="/zh/faq">多模型接入、路由与治理的常见问题</a></li>
    </ul>
  </div>
</Base>

<style>
  /* —— 科技感深色 hero:深海蓝绿底 + 电路点阵 + 金色寻路核心(复用产品动图) —— */
  .hero {
    position: relative;
    overflow: hidden;
    border: 1px solid rgba(120, 180, 160, 0.16);
    border-radius: 18px;
    padding: 2.25rem 2.25rem 2rem;
    margin: 0.75rem 0 2.5rem;
    color: #e6f2ea;
    background:
      radial-gradient(82% 120% at 86% 8%, rgba(215, 166, 66, 0.16) 0%, rgba(215, 166, 66, 0.05) 30%, rgba(7, 17, 16, 0) 58%),
      radial-gradient(70% 120% at 6% 100%, rgba(34, 110, 96, 0.22) 0%, rgba(7, 17, 16, 0) 55%),
      linear-gradient(150deg, #0b1a18 0%, #07130f 52%, #060f12 100%);
    box-shadow: 0 22px 50px rgba(6, 14, 14, 0.4);
  }
  /* 电路点阵 + 细网格层 */
  .hero-fx {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background-image:
      radial-gradient(rgba(120, 200, 175, 0.16) 1px, transparent 1.4px),
      linear-gradient(rgba(120, 200, 175, 0.05) 1px, transparent 1px),
      linear-gradient(90deg, rgba(120, 200, 175, 0.05) 1px, transparent 1px);
    background-size: 22px 22px, 22px 22px, 22px 22px;
    background-position: -1px -1px, 0 0, 0 0;
    -webkit-mask-image: radial-gradient(120% 90% at 70% 30%, #000 35%, transparent 78%);
    mask-image: radial-gradient(120% 90% at 70% 30%, #000 35%, transparent 78%);
    opacity: 0.5;
  }
  .hero-inner {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: 1.5rem;
    align-items: center;
  }
  .hero-chip {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.3rem 0.75rem;
    border: 1px solid rgba(215, 166, 66, 0.4);
    border-radius: 999px;
    background: rgba(215, 166, 66, 0.08);
    color: #f2c75c;
    font-size: 0.76rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
  }
  .chip-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: #f2c75c;
    box-shadow: 0 0 0 0 rgba(242, 199, 92, 0.6);
    animation: chipPulse 2.4s ease-out infinite;
  }
  @keyframes chipPulse {
    0% { box-shadow: 0 0 0 0 rgba(242, 199, 92, 0.55); }
    70%, 100% { box-shadow: 0 0 0 7px rgba(242, 199, 92, 0); }
  }
  .hero h1 {
    margin: 0.85rem 0 0.5rem;
    color: #fff;
    font-size: 2rem;
    line-height: 1.25;
    letter-spacing: 0.01em;
  }
  .hero-slogan {
    margin: 0;
    font-weight: 600;
    font-size: 1.05rem;
    color: #ffe6a8;
  }
  .hero-slogan-en {
    margin: 0.25rem 0 0;
    font-size: 0.85rem;
    color: #93bdab;
    font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
  }
  .hero-cta {
    display: flex;
    gap: 0.7rem;
    flex-wrap: wrap;
    margin: 1.35rem 0 0;
  }
  .btn {
    display: inline-block;
    padding: 0.55rem 1.15rem;
    border-radius: 10px;
    font-size: 0.92rem;
    font-weight: 600;
    line-height: 1.5;
    transition: background 0.15s ease, border-color 0.15s ease, color 0.15s ease, box-shadow 0.15s ease;
  }
  .btn:hover {
    text-decoration: none;
  }
  .btn-solid {
    background: linear-gradient(180deg, #f2c75c, #d7a642);
    color: #1a1205;
    box-shadow: 0 6px 18px rgba(215, 166, 66, 0.28);
  }
  .btn-solid:hover {
    background: linear-gradient(180deg, #f6d271, #e0b14e);
  }
  .btn-ghost {
    border: 1px solid rgba(174, 244, 212, 0.34);
    color: #d3efe1;
  }
  .btn-ghost:hover {
    border-color: rgba(174, 244, 212, 0.7);
    color: #fff;
  }
  .hero-core {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.6rem;
  }
  .hero-core :global(.hero-core-viz) {
    filter: drop-shadow(0 0 28px rgba(215, 166, 66, 0.22));
  }
  .hero-core-cap {
    margin: 0;
    font-size: 0.78rem;
    color: #9fb8ad;
    text-align: center;
    font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
  }
  .hero-core-cap b {
    color: #f2c75c;
    font-weight: 600;
  }
  .cap-on {
    color: #7ee6b6;
  }
  @media (max-width: 600px) {
    .hero {
      padding: 1.5rem 1.25rem 1.5rem;
    }
    .hero-inner {
      grid-template-columns: 1fr;
      gap: 0.5rem;
    }
    .hero-core {
      order: -1;
    }
    .hero-core :global(.hero-core-viz) {
      width: 240px !important;
      height: 240px !important;
    }
  }

  .trust {
    display: grid;
    gap: 1rem;
    margin: 1.25rem 0 2rem;
  }
  .trust-card {
    position: relative;
    overflow: hidden;
    border: 1px solid var(--line);
    border-left: 4px solid var(--core);
    border-radius: 12px;
    background: var(--soft);
    padding: 1rem 1.2rem;
  }
  @media (hover: hover) {
    .trust-card {
      transition: transform 0.18s ease, box-shadow 0.18s ease;
    }
    .trust-card:hover {
      transform: translateY(-2px);
      box-shadow: 0 10px 26px rgba(18, 60, 52, 0.1);
    }
  }
  .trust-num {
    position: absolute;
    top: 0.1rem;
    right: 0.75rem;
    font-size: 3rem;
    font-weight: 800;
    line-height: 1.4;
    color: rgba(18, 60, 52, 0.07);
    pointer-events: none;
    user-select: none;
  }
  .trust-card h3 {
    margin: 0.25rem 0 0.4rem;
    color: var(--core);
  }
  .trust-card p {
    margin: 0;
  }
  .trust-tag {
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    color: var(--node);
  }

  /* 终端式代码块:外观层;pre 基础样式沿用全局 */
  .codeblock {
    margin: 1rem 0;
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid rgba(18, 60, 52, 0.5);
    box-shadow: 0 10px 30px rgba(7, 19, 15, 0.16);
  }
  .codeblock figcaption {
    display: flex;
    align-items: center;
    gap: 0.42rem;
    padding: 0.55rem 1rem;
    background: #0d2a22;
    border-bottom: 1px solid rgba(95, 214, 163, 0.14);
  }
  .dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
  }
  .d1 { background: #1d5c49; }
  .d2 { background: #2f7d5e; }
  .d3 { background: #5fd6a3; }
  .codefile {
    margin-left: auto;
    font-size: 0.78rem;
    color: #9fc7b6;
    font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
  }
  .codeblock pre {
    margin: 0;
    border-radius: 0;
  }
  .codeblock :global(.k) { color: #8fe6bf; }
  .codeblock :global(.s) { color: #b6f5d8; }
  .codeblock :global(.c) { color: #6f8d80; }

  .advisor {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
    border: 1px solid var(--line);
    border-radius: 12px;
    padding: 1.1rem 1.2rem;
    background: #fff;
  }
  .advisor-mono {
    flex: none;
    display: grid;
    place-items: center;
    width: 46px;
    height: 46px;
    border-radius: 50%;
    background: var(--soft);
    border: 1px solid var(--line);
    color: var(--core);
    font-weight: 700;
    font-size: 1.15rem;
  }
  .advisor-name {
    margin: 0 0 0.4rem;
    color: var(--core);
  }
  .advisor p:last-child {
    margin: 0;
  }
</style>

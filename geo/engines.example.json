{
  "_meta": {
    "usage": "复制为 geo/engines.json(已 gitignore)后填真实值;密钥一律走环境变量,文件内只写变量名",
    "modes": "C1 双模式:web = 联网检索(快变量,吃 Bing/百度索引);model = 纯模型记忆(慢变量,吃训练语料)。引擎支持开关则两种都跑",
    "dogfooding": "API 引擎优先经 SMA 网关 BYOK 调用(顺手成为产品演示素材);Perplexity 走官方 API"
  },
  "api_engines": [
    {
      "name": "sma-gateway-deepseek",
      "kind": "openai-compatible",
      "base_url": "https://demo.smaapi.com/v1",
      "model": "<网关侧模型名>",
      "api_key_env": "SMA_API_KEY",
      "modes": { "model": {} }
    },
    {
      "name": "perplexity",
      "kind": "openai-compatible",
      "base_url": "https://api.perplexity.ai",
      "model": "sonar",
      "api_key_env": "PERPLEXITY_API_KEY",
      "modes": { "web": {} }
    },
    {
      "name": "sma-gateway-kimi",
      "kind": "openai-compatible",
      "base_url": "https://demo.smaapi.com/v1",
      "model": "<网关侧模型名>",
      "api_key_env": "SMA_API_KEY",
      "modes": { "model": {}, "web": { "enable_search": true } }
    }
  ],
  "manual_engines": ["ChatGPT Search", "豆包", "元宝", "夸克", "秘塔", "Google AI Overviews"]
}
